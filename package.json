{
  "name": "whisper-api",
  "version": "0.1.2",
  "description": "Self-hostable, OpenAI-compatible Whisper speech-to-text API server you can run anywhere with npx. Local inference via whisper.cpp or ONNX (transformers.js).",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Alexey Abramov <alexeyabramov@gmail.com>",
  "homepage": "https://github.com/alexey-a-abramov/whisper-api#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexey-a-abramov/whisper-api.git"
  },
  "bugs": {
    "url": "https://github.com/alexey-a-abramov/whisper-api/issues"
  },
  "keywords": [
    "whisper",
    "whisper.cpp",
    "speech-to-text",
    "transcription",
    "stt",
    "openai",
    "openai-compatible",
    "api",
    "self-hosted",
    "asr",
    "transformers.js",
    "onnx"
  ],
  "bin": {
    "whisper-api": "bin/whisper-api.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "bin",
    "web",
    "deploy",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "start": "node bin/whisper-api.js start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node scripts/sync-version.mjs && git add src/version.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@huggingface/transformers": "^4.2.0",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ffmpeg-static": "^5.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^26.0.0",
    "form-data": "^4.0.6",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
