# whisper-api environment overrides (copy to .env). All are optional.

# Where config, keys, models and caches live (default: ~/.whisper-api)
# WHISPER_API_HOME=/var/lib/whisper-api

# Server
# WHISPER_API_HOST=0.0.0.0
# WHISPER_API_PORT=8080
# WHISPER_API_ENGINE=auto          # auto | whispercpp | onnx
# WHISPER_API_MODEL=base.en
# WHISPER_API_MAX_UPLOAD_MB=25
# WHISPER_API_RATE_MAX=120         # requests per minute, per key

# Auth: a fixed personal API key accepted by the server, in addition to any keys
# made with `whisper-api key generate`. Handy for a single-user endpoint.
# (Equivalent to: whisper-api start --api-key <token>)
# WHISPER_API_KEY=sk-my-personal-secret

# Engine tuning
# WHISPER_API_AUTOBUILD=1          # allow `auto` to build whisper.cpp from source
# WHISPER_CPP_BIN=/usr/local/bin/whisper-cli
# WHISPER_API_ONNX_DEVICE=cpu      # cpu | cuda (requires onnxruntime GPU)
# WHISPER_API_ONNX_DTYPE=fp32      # fp32 | q8 | q4
# FFMPEG_PATH=/usr/bin/ffmpeg      # override the bundled ffmpeg-static binary

# Logging
# WHISPER_API_LOG=info             # trace|debug|info|warn|error|silent
